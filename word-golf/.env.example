# Copy to .env and fill in. .env is gitignored; never commit real values.
#
# --- App runtime (browser) ---
# LaunchDarkly *client-side ID* for your APP project's environment. This is the
# only credential the web app needs. When blank, the app runs offline with safe
# flag defaults and metric tracking is a no-op (the game still works fully).
VITE_LD_CLIENT_ID=

# ----------------------------------------------------------------------------
# The values below are NOT used by the app at runtime. They belong in the
# AutoFactory bootstrap (run from the launchdarkly-auto-factory repo) and as
# GitHub Actions secrets/variables on this repo. Listed here for convenience.
# ----------------------------------------------------------------------------
#
# --- AutoFactory: GitHub Actions secrets (set in repo Settings > Secrets) ---
# Factory project server SDK key (sdk-...): reads agent configs + graph.
LD_SDK_KEY=
# LD API token (api-...) with write access to the app project: creates flags/metrics.
LD_API_KEY=
# Anthropic API key: default agent execution backend.
ANTHROPIC_API_KEY=
#
# --- AutoFactory: GitHub Actions variable (set in repo Settings > Variables) ---
# Your LaunchDarkly app project key (where agents create flags/metrics).
LD_APP_PROJECT_KEY=word-golf
